PROXY_PLATFORM_OPERATOR_IMAGE=proxy-platform-operator:local
PROXY_PLATFORM_OPERATOR_MODE=operator
PROXY_PLATFORM_OPERATOR_PUBLIC_HOST=proxy-platform-operator.svc.prod.lab.gglohh.top
PROXY_PLATFORM_OPERATOR_HOST_PORT=18082
PROXY_PLATFORM_OPERATOR_BASIC_AUTH_USERNAME=admin
# Set a real password before first start. Blank means the runtime will refuse to boot.
PROXY_PLATFORM_OPERATOR_BASIC_AUTH_PASSWORD=
PROXY_PLATFORM_CONTROL_PLANE_BASE_URL=https://cliproxy-control-plane.svc.prod.lab.gglohh.top:27111
PROXY_PLATFORM_CONTROL_PLANE_USERNAME=admin
# Set a real control-plane read password before enabling worker quota view.
PROXY_PLATFORM_CONTROL_PLANE_PASSWORD=
PROXY_PLATFORM_CONTROL_PLANE_TIMEOUT_SECONDS=10
